<h2 style='color:#1a1a1a;margin:0 0 16px 0;'>Factura {{invoiceNumber}}</h2>
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Hola {{firstName}},</p>
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Su factura de {{companyName}} está lista.</p>
<table style='width:100%;border-collapse:collapse;margin:0 0 16px 0;'>
  <tr><td style='padding:6px 0;color:#6b7280;'>Estado</td><td style='padding:6px 0;color:#1a1a1a;text-align:right;'>{{status}}</td></tr>
  <tr><td style='padding:6px 0;color:#6b7280;'>Emitida</td><td style='padding:6px 0;color:#1a1a1a;text-align:right;'>{{issuedAt}}</td></tr>
  <tr><td style='padding:6px 0;color:#6b7280;'>Vencimiento</td><td style='padding:6px 0;color:#1a1a1a;text-align:right;'>{{dueAt}}</td></tr>
  <tr><td style='padding:6px 0;color:#1a1a1a;'><strong>Total</strong></td><td style='padding:6px 0;color:#1a1a1a;text-align:right;'><strong>{{total}}</strong></td></tr>
</table>
