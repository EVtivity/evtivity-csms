<p style='color:#1a1a1a;line-height:1.6;margin:0 0 16px 0;'><strong>Mantenimiento:</strong> {{maintenanceEventId}}<br/><strong>Ventana:</strong> {{plannedStartAt}} a {{plannedEndAt}}{{#if reason}}<br/><strong>Motivo:</strong> {{reason}}{{/if}}</p>
