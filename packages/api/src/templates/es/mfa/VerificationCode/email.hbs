{{#if firstName}}<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Hola
    {{firstName}},</p>{{/if}}
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Su codigo de verificacion es:</p>
<p style='text-align:center;margin:24px 0;'>
  <span style='font-size:32px;font-weight:700;letter-spacing:8px;color:#1a1a1a;'>{{code}}</span>
</p>
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Este codigo expira en 5 minutos. Si no
  solicito este codigo, puede ignorar este correo.</p>