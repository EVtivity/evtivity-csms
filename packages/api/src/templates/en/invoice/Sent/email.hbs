<h2 style='color:#1a1a1a;margin:0 0 16px 0;'>Invoice {{invoiceNumber}}</h2>
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Hi {{firstName}},</p>
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Your invoice from {{companyName}} is ready.</p>
<table style='width:100%;border-collapse:collapse;margin:0 0 16px 0;'>
  <tr><td style='padding:6px 0;color:#6b7280;'>Status</td><td style='padding:6px 0;color:#1a1a1a;text-align:right;'>{{status}}</td></tr>
  <tr><td style='padding:6px 0;color:#6b7280;'>Issued</td><td style='padding:6px 0;color:#1a1a1a;text-align:right;'>{{issuedAt}}</td></tr>
  <tr><td style='padding:6px 0;color:#6b7280;'>Due</td><td style='padding:6px 0;color:#1a1a1a;text-align:right;'>{{dueAt}}</td></tr>
  <tr><td style='padding:6px 0;color:#1a1a1a;'><strong>Total</strong></td><td style='padding:6px 0;color:#1a1a1a;text-align:right;'><strong>{{total}}</strong></td></tr>
</table>
