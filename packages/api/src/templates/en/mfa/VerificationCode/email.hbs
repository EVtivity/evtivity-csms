{{#if firstName}}<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Hi
    {{firstName}},</p>{{/if}}
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Your verification code is:</p>
<p style='text-align:center;margin:24px 0;'>
  <span style='font-size:32px;font-weight:700;letter-spacing:8px;color:#1a1a1a;'>{{code}}</span>
</p>
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>This code expires in 5 minutes. If you
  did not request this code, you can ignore this email.</p>