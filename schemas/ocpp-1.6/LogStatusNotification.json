{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "urn:OCPP:1.6:2019:12:LogStatusNotificationRequest",
  "title": "LogStatusNotificationRequest",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "additionalProperties": false,
      "enum": [
        "BadMessage",
        "Idle",
        "NotSupportedOperation",
        "PermissionDenied",
        "Uploaded",
        "UploadFailure",
        "Uploading"
      ]
    },
    "requestId": {
      "type": "integer"
    }
  },
  "additionalProperties": false,
  "required": ["status"]
}
